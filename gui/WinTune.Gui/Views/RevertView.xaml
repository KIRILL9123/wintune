<UserControl x:Class="WinTune.Gui.Views.RevertView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WinTune.Gui.ViewModels">
  <UserControl.DataContext>
    <vm:RevertViewModel />
  </UserControl.DataContext>

  <Grid Margin="32">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Text="Rollback History" FontSize="24" FontWeight="SemiBold" />
    <TextBlock Grid.Row="1" Text="Restore system state from a previous session."
               FontSize="13" Foreground="{ThemeResource TextFillSecondaryBrush}"
               Margin="0,4,0,20" />

    <ProgressRing Grid.Row="2" IsActive="{Binding IsLoading}"
                  Width="32" Height="32" VerticalAlignment="Top" Margin="0,16"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

    <Border Grid.Row="2" VerticalAlignment="Top" Background="#482222"
            CornerRadius="8" Padding="16,12"
            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <FontIcon Glyph="&#xE783;" FontSize="16" Foreground="#EA3943"
                  VerticalAlignment="Center" Margin="0,0,12,0" />
        <TextBlock Grid.Column="1" Text="{Binding Error}" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Border Grid.Row="2" CornerRadius="12" VerticalAlignment="Top"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="32"
            Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
      <StackPanel HorizontalAlignment="Center">
        <FontIcon Glyph="&#xE81C;" FontSize="40"
                  Foreground="{ThemeResource TextFillSecondaryBrush}"
                  HorizontalAlignment="Center" />
        <TextBlock Text="No backup sessions found" FontSize="16" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,8,0,0" />
        <TextBlock Text="Apply a profile first to create backups."
                   FontSize="13" Foreground="{ThemeResource TextFillSecondaryBrush}"
                   HorizontalAlignment="Center" />
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Sessions}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border MinHeight="80" Margin="0,0,0,8" Padding="20,16"
                    CornerRadius="10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Session" FontSize="14" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SessionId}" FontSize="14" Margin="8,0,0,0"
                               Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="{Binding ProfileName}" FontSize="13" FontWeight="SemiBold" />
                    <TextBlock Margin="12,0,0,0" FontSize="12"
                               Foreground="{ThemeResource TextFillSecondaryBrush}">
                      <Run Text="{Binding Timestamp}" />
                    </TextBlock>
                  </StackPanel>
                  <TextBlock Margin="0,6,0,0" FontSize="12"
                             Foreground="{ThemeResource TextFillSecondaryBrush}">
                    <Run Text="{Binding ChangeCount}" />
                    <Run Text=" changes (" />
                    <Run Text="{Binding SuccessCount}" Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                    <Run Text=" succeeded)" />
                  </TextBlock>
                </StackPanel>
                <Button Grid.Column="1" VerticalAlignment="Center" Width="100" Height="36">
                  <StackPanel Orientation="Horizontal">
                    <FontIcon Glyph="&#xE81C;" FontSize="14" Margin="0,0,6,0" />
                    <TextBlock Text="Revert" />
                  </StackPanel>
                </Button>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
