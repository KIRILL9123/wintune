<UserControl x:Class="WinTune.Gui.Views.RevertView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WinTune.Gui.ViewModels">
  <UserControl.DataContext>
    <vm:RevertViewModel />
  </UserControl.DataContext>

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Text="Revert" FontSize="28" FontWeight="SemiBold" />

    <DataGrid Grid.Row="1" ItemsSource="{Binding Sessions}" AutoGenerateColumns="False" Margin="0,24,0,0">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Session" Binding="{Binding SessionId}" Width="2*" />
        <DataGridTextColumn Header="Profile" Binding="{Binding ProfileName}" Width="*" />
        <DataGridTextColumn Header="Changes" Binding="{Binding ChangeCount}" Width="80" />
        <DataGridTextColumn Header="Succeeded" Binding="{Binding SuccessCount}" Width="80" />
        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat='{}{0:g}'}" Width="2*" />
        <DataGridTemplateColumn Header="Action" Width="100">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <Button Content="Revert" Width="80" />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
