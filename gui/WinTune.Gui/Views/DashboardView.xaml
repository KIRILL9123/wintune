<UserControl x:Class="WinTune.Gui.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WinTune.Gui.ViewModels">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="32">
      <Grid Margin="0,0,0,24">
        <StackPanel>
          <TextBlock Text="Dashboard" FontSize="24" FontWeight="SemiBold" />
          <TextBlock Text="{Binding LastScanText}" FontSize="13"
                     Foreground="{ThemeResource TextFillSecondaryBrush}"
                     Margin="0,4,0,0" />
        </StackPanel>
      </Grid>

      <!-- Error -->
      <Border Background="#482222" CornerRadius="8" Padding="16,12" Margin="0,0,0,16"
              Visibility="{Binding HasError}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <FontIcon Glyph="&#xE783;" FontSize="16" Margin="0,0,12,0" Foreground="#EA3943" />
          <TextBlock Grid.Column="1" Text="{Binding Error}" VerticalAlignment="Center" TextWrapping="Wrap" />
        </Grid>
      </Border>

      <!-- Loading -->
      <ProgressRing IsActive="{Binding IsLoading}" Width="32" Height="32" Margin="0,8"
                    Visibility="{Binding IsLoading}" />

      <!-- Score -->
      <Grid Margin="0,0,0,20" Visibility="{Binding IsLoaded}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Width="120" Height="120" CornerRadius="60"
                Background="{ThemeResource AccentFillColorDefaultBrush}">
          <TextBlock Text="{Binding DebloatScore}" FontSize="40" FontWeight="Bold"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Foreground="White" />
        </Border>
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
          <TextBlock FontSize="14" Foreground="{ThemeResource TextFillSecondaryBrush}"
                     Text="Debloat Score" />
          <TextBlock FontSize="36" FontWeight="Bold" Margin="0,4,0,0"
                     Text="{Binding DebloatScore}" />
          <TextBlock FontSize="13" Foreground="{ThemeResource TextFillSecondaryBrush}" Margin="0,6,0,0">
            <Run Text="{Binding RemovedCount}" FontWeight="SemiBold" />
            <Run Text=" of " />
            <Run Text="{Binding TotalCount}" FontWeight="SemiBold" />
            <Run Text=" items cleaned" />
          </TextBlock>
        </StackPanel>
      </Grid>

      <!-- Stats Grid -->
      <Grid Margin="0,0,0,20" Visibility="{Binding IsLoaded}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" CornerRadius="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Padding="20,16" Margin="0,0,8,8">
          <StackPanel>
            <FontIcon Glyph="&#xE766;" FontSize="18" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
            <TextBlock Text="Packages" FontSize="12" Margin="0,4,0,0"
                       Foreground="{ThemeResource TextFillSecondaryBrush}" />
            <TextBlock Text="{Binding PackageCount}" FontSize="22" FontWeight="SemiBold" />
          </StackPanel>
        </Border>
        <Border Grid.Column="1" CornerRadius="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Padding="20,16" Margin="0,0,8,8">
          <StackPanel>
            <FontIcon Glyph="&#xE795;" FontSize="18" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
            <TextBlock Text="Services" FontSize="12" Margin="0,4,0,0"
                       Foreground="{ThemeResource TextFillSecondaryBrush}" />
            <TextBlock Text="{Binding RunningServiceCount}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding TotalServiceCount}" FontSize="11"
                       Foreground="{ThemeResource TextFillSecondaryBrush}" />
          </StackPanel>
        </Border>
        <Border Grid.Column="2" CornerRadius="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Padding="20,16" Margin="0,0,0,8">
          <StackPanel>
            <FontIcon Glyph="&#xE950;" FontSize="18" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
            <TextBlock Text="Processes" FontSize="12" Margin="0,4,0,0"
                       Foreground="{ThemeResource TextFillSecondaryBrush}" />
            <TextBlock Text="{Binding ProcessCount}" FontSize="22" FontWeight="SemiBold" />
          </StackPanel>
        </Border>
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" CornerRadius="10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                Padding="20,16" Margin="0,0,0,0">
          <StackPanel>
            <FontIcon Glyph="&#xE90F;" FontSize="18" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
            <TextBlock Text="Idle RAM" FontSize="12" Margin="0,4,0,0"
                       Foreground="{ThemeResource TextFillSecondaryBrush}" />
            <TextBlock Text="{Binding IdleRamMB}" FontSize="22" FontWeight="SemiBold" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- Actions -->
      <StackPanel Visibility="{Binding IsLoaded}">
        <TextBlock Text="Quick Actions" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
        <StackPanel Orientation="Horizontal">
          <Button Width="130" Height="38" Margin="0,0,12,0"
                  Style="{ThemeResource AccentButtonStyle}" x:Name="AuditBtn">
            <StackPanel Orientation="Horizontal">
              <FontIcon Glyph="&#xE714;" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Audit" />
            </StackPanel>
          </Button>
          <Button Width="130" Height="38" Margin="0,0,12,0" x:Name="ApplyBtn">
            <StackPanel Orientation="Horizontal">
              <FontIcon Glyph="&#xE768;" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Apply" />
            </StackPanel>
          </Button>
          <Button Width="130" Height="38" x:Name="RevertBtn">
            <StackPanel Orientation="Horizontal">
              <FontIcon Glyph="&#xE81C;" FontSize="14" Margin="0,0,8,0" />
              <TextBlock Text="Revert" />
            </StackPanel>
          </Button>
        </StackPanel>
      </StackPanel>

      <!-- Empty State -->
      <Border CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              Padding="32" Margin="0,12,0,0" Visibility="{Binding IsEmpty}">
        <StackPanel HorizontalAlignment="Center">
          <FontIcon Glyph="&#xE712;" FontSize="40"
                    Foreground="{ThemeResource TextFillSecondaryBrush}"
                    HorizontalAlignment="Center" />
          <TextBlock Text="No data available" FontWeight="SemiBold" FontSize="16"
                     HorizontalAlignment="Center" Margin="0,8,0,0" />
          <TextBlock Text="Click Audit to scan your system."
                     FontSize="13" Foreground="{ThemeResource TextFillSecondaryBrush}"
                     HorizontalAlignment="Center" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
