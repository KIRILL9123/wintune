<UserControl x:Class="WinTune.Gui.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WinTune.Gui.ViewModels"
             xmlns:modern="http://schemas.modernwpf.com/2019">
  <UserControl.DataContext>
    <vm:DashboardViewModel />
  </UserControl.DataContext>

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Text="Dashboard" FontSize="28" FontWeight="SemiBold" />

    <Grid Grid.Row="1" Margin="0,24,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" />
        <ColumnDefinition Width="3*" />
      </Grid.ColumnDefinitions>

      <Border CornerRadius="12" Background="#1A1F2E" Padding="24" Margin="0,0,16,0">
        <StackPanel>
          <TextBlock Text="Debloat Score" FontSize="16" Foreground="#8B949E" />
          <TextBlock Text="{Binding DebloatScore}" FontSize="64" FontWeight="Bold" Margin="0,12,0,0" />
          <TextBlock Text="%" FontSize="20" Margin="0,-18,0,0" Foreground="#8B949E" />
          <TextBlock Text="{Binding LastScanText}" Margin="0,16,0,0" Foreground="#8B949E" FontSize="12" />
          <TextBlock Text="{Binding Error}" Margin="0,4,0,0" Foreground="#EA3943" FontSize="12" />
          <modern:ProgressRing IsActive="{Binding IsLoading}" Width="24" Height="24" Margin="0,8,0,0" />
        </StackPanel>
      </Border>

      <Border Grid.Column="1" CornerRadius="12" Background="#121826" Padding="24">
        <StackPanel>
          <TextBlock Text="Actions" FontSize="16" Foreground="#8B949E" />
          <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
            <Button Content="Audit" Width="120" Margin="0,0,12,0" />
            <Button Content="Apply" Width="120" Margin="0,0,12,0" />
            <Button Content="Revert" Width="120" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>
