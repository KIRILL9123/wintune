<UserControl x:Class="WinTune.Gui.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WinTune.Gui.ViewModels"
             xmlns:ui="http://schemas.modernwpf.com/2019">
  <UserControl.DataContext>
    <vm:DashboardViewModel />
  </UserControl.DataContext>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="32">
      <Grid Margin="0,0,0,24">
        <StackPanel>
          <TextBlock Text="Dashboard" FontSize="24" FontWeight="SemiBold" />
          <TextBlock Text="{Binding LastScanText}"
                     FontSize="13"
                     Foreground="{ui:ThemeResource TextFillSecondaryBrush}"
                     Margin="0,4,0,0" />
        </StackPanel>
      </Grid>

      <!-- Error -->
      <Border Background="#482222" CornerRadius="8" Padding="16,12" Margin="0,0,0,16"
              Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                     VerticalAlignment="Center" Margin="0,0,12,0" Foreground="#EA3943" />
          <TextBlock Grid.Column="1" Text="{Binding Error}" VerticalAlignment="Center"
                     TextWrapping="Wrap" />
        </Grid>
      </Border>

      <!-- Loading -->
      <ui:ProgressRing IsActive="{Binding IsLoading}"
                       Width="32" Height="32" Margin="0,8"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />

      <!-- Score -->
      <Grid Margin="0,0,0,20"
            Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVisibility}}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Width="120" Height="120" CornerRadius="60"
                Background="{ui:ThemeResource SystemAccentColorDarkBrush}"
                VerticalAlignment="Center">
          <TextBlock Text="{Binding DebloatScore}" FontSize="40" FontWeight="Bold"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Foreground="White" />
        </Border>

        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
          <TextBlock FontSize="14" Foreground="{ui:ThemeResource TextFillSecondaryBrush}"
                     Text="Debloat Score" />
          <TextBlock FontSize="36" FontWeight="Bold" Margin="0,4,0,0"
                     Text="{Binding DebloatScore, StringFormat='{}{0}%'}" />
          <TextBlock FontSize="13" Foreground="{ui:ThemeResource TextFillSecondaryBrush}" Margin="0,6,0,0">
            <Run Text="{Binding RemovedCount, Mode=OneWay}" FontWeight="SemiBold" />
            <Run Text=" of " />
            <Run Text="{Binding TotalCount, Mode=OneWay}" FontWeight="SemiBold" />
            <Run Text=" items cleaned" />
          </TextBlock>
        </StackPanel>
      </Grid>

      <!-- Stats Grid -->
      <Grid Margin="0,0,0,20"
            Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVisibility}}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.Resources>
          <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="Padding" Value="20,16" />
            <Setter Property="Margin" Value="0,0,8,8" />
          </Style>
        </Grid.Resources>

        <Border Grid.Column="0">
          <StackPanel>
            <TextBlock Text="&#xE766;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                       Foreground="{ui:ThemeResource SystemAccentColorBrush}" />
            <TextBlock Text="Packages" FontSize="12" Margin="0,4,0,0"
                       Foreground="{ui:ThemeResource TextFillSecondaryBrush}" />
            <TextBlock Text="{Binding PackageCount}" FontSize="22" FontWeight="SemiBold" />
          </StackPanel>
        </Border>
        <Border Grid.Column="1">
          <StackPanel>
            <TextBlock Text="&#xE795;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                       Foreground="{ui:ThemeResource SystemAccentColorBrush}" />
            <TextBlock Text="Services" FontSize="12" Margin="0,4,0,0"
                       Foreground="{ui:ThemeResource TextFillSecondaryBrush}" />
            <TextBlock Text="{Binding RunningServiceCount}" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Text="{Binding TotalServiceCount, StringFormat='{}/ {0} total'}" FontSize="11"
                       Foreground="{ui:ThemeResource TextFillSecondaryBrush}" />
          </StackPanel>
        </Border>
        <Border Grid.Column="2" Margin="0,0,0,8">
          <StackPanel>
            <TextBlock Text="&#xE950;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                       Foreground="{ui:ThemeResource SystemAccentColorBrush}" />
            <TextBlock Text="Processes" FontSize="12" Margin="0,4,0,0"
                       Foreground="{ui:ThemeResource TextFillSecondaryBrush}" />
            <TextBlock Text="{Binding ProcessCount}" FontSize="22" FontWeight="SemiBold" />
          </StackPanel>
        </Border>
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,0">
          <StackPanel>
            <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                       Foreground="{ui:ThemeResource SystemAccentColorBrush}" />
            <TextBlock Text="Idle RAM" FontSize="12" Margin="0,4,0,0"
                       Foreground="{ui:ThemeResource TextFillSecondaryBrush}" />
            <TextBlock Text="{Binding IdleRamMB, StringFormat='{}{0} MB'}" FontSize="22" FontWeight="SemiBold" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- Actions -->
      <StackPanel Visibility="{Binding IsLoaded, Converter={StaticResource BoolToVisibility}}">
        <TextBlock Text="Quick Actions" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
        <StackPanel Orientation="Horizontal">
          <Button Width="130" Height="38" Margin="0,0,12,0"
                  Style="{ui:ThemeResource AccentButtonStyle}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" />
              <TextBlock Text="Audit" />
            </StackPanel>
          </Button>
          <Button Width="130" Height="38" Margin="0,0,12,0">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" />
              <TextBlock Text="Apply" />
            </StackPanel>
          </Button>
          <Button Width="130" Height="38">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" />
              <TextBlock Text="Revert" />
            </StackPanel>
          </Button>
        </StackPanel>
      </StackPanel>

      <!-- Empty State -->
      <Border CornerRadius="12"
              Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
              Padding="32" Margin="0,12,0,0"
              Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
        <StackPanel HorizontalAlignment="Center">
          <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="40"
                     Foreground="{ui:ThemeResource TextFillSecondaryBrush}"
                     HorizontalAlignment="Center" />
          <TextBlock Text="No data available" FontWeight="SemiBold" FontSize="16"
                     HorizontalAlignment="Center" Margin="0,8,0,0" />
          <TextBlock Text="Click Audit to scan your system."
                     FontSize="13"
                     Foreground="{ui:ThemeResource TextFillSecondaryBrush}"
                     HorizontalAlignment="Center" Margin="0,2,0,0" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
