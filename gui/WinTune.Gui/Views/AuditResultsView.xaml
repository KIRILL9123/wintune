<UserControl x:Class="WinTune.Gui.Views.AuditResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WinTune.Gui.ViewModels">
  <UserControl.DataContext>
    <vm:AuditResultsViewModel />
  </UserControl.DataContext>

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Text="Audit Results" FontSize="28" FontWeight="SemiBold" />

    <DataGrid Grid.Row="1" ItemsSource="{Binding Rows}" AutoGenerateColumns="False" Margin="0,24,0,0">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Tweak ID" Binding="{Binding TweakId}" Width="2*" />
        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*" />
        <DataGridTextColumn Header="Risk" Binding="{Binding Risk}" Width="*" />
        <DataGridTextColumn Header="State" Binding="{Binding State}" Width="*" />
        <DataGridCheckBoxColumn Header="Include" Binding="{Binding Include}" Width="*" />
      </DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
