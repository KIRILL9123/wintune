<UserControl x:Class="WinTune.Gui.Views.AuditResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WinTune.Gui.ViewModels">
  <UserControl.DataContext>
    <vm:AuditResultsViewModel />
  </UserControl.DataContext>

  <Grid Margin="32">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <TextBlock Text="Audit Results" FontSize="24" FontWeight="SemiBold" />
    <Button Grid.Column="1" Width="140" Height="36"
            Style="{ThemeResource AccentButtonStyle}" x:Name="RunBtn">
      <StackPanel Orientation="Horizontal">
        <FontIcon Glyph="&#xE72C;" FontSize="14" Margin="0,0,8,0" />
        <TextBlock Text="Run Audit" />
      </StackPanel>
    </Button>

    <!-- Score -->
    <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,16,0,20">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Border Width="80" Height="80" CornerRadius="40"
              Background="{ThemeResource AccentFillColorDefaultBrush}">
        <TextBlock Text="{Binding Score}" FontSize="28" FontWeight="Bold"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Foreground="White" />
      </Border>
      <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
        <TextBlock FontSize="15" Text="Debloat Score" FontWeight="SemiBold" />
        <TextBlock FontSize="13" Foreground="{ThemeResource TextFillSecondaryBrush}" Margin="0,4,0,0">
          <Run Text="{Binding Present}" FontWeight="SemiBold" />
          <Run Text=" items present out of " />
          <Run Text="{Binding Total}" FontWeight="SemiBold" />
        </TextBlock>
      </StackPanel>
    </Grid>

    <ProgressRing Grid.Row="2" Grid.ColumnSpan="2" IsActive="{Binding IsLoading}"
                  Width="32" Height="32" VerticalAlignment="Top" Margin="0,16"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />

    <Border Grid.Row="2" Grid.ColumnSpan="2" VerticalAlignment="Top"
            Background="#482222" CornerRadius="8" Padding="16,12"
            Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <FontIcon Glyph="&#xE783;" FontSize="16" Foreground="#EA3943"
                  VerticalAlignment="Center" Margin="0,0,12,0" />
        <TextBlock Grid.Column="1" Text="{Binding Error}" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="2" Grid.ColumnSpan="2" VerticalScrollBarVisibility="Auto">
      <ListView ItemsSource="{Binding Rows}" Margin="0,8,0,0"
                BorderThickness="0" Background="Transparent">
        <ListView.ItemTemplate>
          <DataTemplate>
            <Grid Height="36">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100" />
              </Grid.ColumnDefinitions>
              <FontIcon Glyph="&#xE73E;" FontSize="16" Margin="0,0,12,0"
                        Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
              <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                         FontSize="13" />
              <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <TextBlock Text="{Binding Type}" FontSize="11" HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillSecondaryBrush}" />
              </Border>
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>
    </ScrollViewer>
  </Grid>
</UserControl>
