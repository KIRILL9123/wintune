<UserControl x:Class="WinTune.Gui.Views.ApplyProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WinTune.Gui.ViewModels">
  <UserControl.DataContext>
    <vm:ApplyProgressViewModel />
  </UserControl.DataContext>

  <Grid Margin="32">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Text="Apply Progress" FontSize="24" FontWeight="SemiBold" />
    <TextBlock Grid.Row="1" Text="{Binding StatusText}" FontSize="13"
               Foreground="{ThemeResource TextFillSecondaryBrush}" Margin="0,4,0,20" />

    <Grid Grid.Row="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <ProgressBar Value="{Binding OverallPercent}" Maximum="100" Height="4"
                   IsIndeterminate="{Binding IsLoading}" />

      <ListView Grid.Row="1" ItemsSource="{Binding Rows}" Margin="0,16,0,0"
                BorderThickness="0" Background="Transparent">
        <ListView.ItemTemplate>
          <DataTemplate>
            <Grid Height="36">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <FontIcon Glyph="{Binding StatusGlyph}" FontSize="16"
                        VerticalAlignment="Center" Margin="0,0,12,0"
                        Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
              <TextBlock Grid.Column="1" Text="{Binding TweakId}" VerticalAlignment="Center"
                         FontSize="13" />
              <TextBlock Grid.Column="2" Text="{Binding Status}" VerticalAlignment="Center"
                         FontSize="12" Foreground="{ThemeResource TextFillSecondaryBrush}" />
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>
    </Grid>

    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,20,0,0">
      <TextBlock VerticalAlignment="Center"
                 Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                 FontWeight="SemiBold"
                 Visibility="{Binding IsComplete, Converter={StaticResource BoolToVis}}">
        &#xE73E; Apply complete
      </TextBlock>
    </StackPanel>
  </Grid>
</UserControl>
