<UserControl x:Class="WinTune.Gui.Views.ApplyProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WinTune.Gui.ViewModels"
             xmlns:ui="http://schemas.modernwpf.com/2019">
  <UserControl.DataContext>
    <vm:ApplyProgressViewModel />
  </UserControl.DataContext>

  <Grid Margin="32">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Text="Apply Progress" FontSize="24" FontWeight="SemiBold" />
    <TextBlock Grid.Row="1" Text="{Binding StatusText}"
               FontSize="13" Foreground="{ui:ThemeResource TextFillSecondaryBrush}"
               Margin="0,4,0,20" />

    <!-- Progress -->
    <Grid Grid.Row="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <ui:ProgressBar Value="{Binding OverallPercent}" Maximum="100"
                       Height="4" Margin="0,0,0,0"
                       IsIndeterminate="{Binding IsLoading}" />

      <ListView Grid.Row="1" ItemsSource="{Binding Rows}" Margin="0,16,0,0"
                BorderThickness="0" Background="Transparent">
        <ListView.ItemTemplate>
          <DataTemplate>
            <Grid Height="36">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="{Binding StatusGlyph}" FontFamily="Segoe MDL2 Assets"
                         FontSize="16" VerticalAlignment="Center" Margin="0,0,12,0"
                         Foreground="{ui:ThemeResource SystemAccentColorBrush}" />
              <TextBlock Grid.Column="1" Text="{Binding TweakId}" VerticalAlignment="Center"
                         FontSize="13" />
              <TextBlock Grid.Column="2" Text="{Binding Status}" VerticalAlignment="Center"
                         FontSize="12"
                         Foreground="{ui:ThemeResource TextFillSecondaryBrush}" />
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>
      </ListView>
    </Grid>

    <!-- Actions -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,20,0,0">
      <Button Width="120" Height="38" Margin="0,0,12,0"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="&#xE10A;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" />
          <TextBlock Text="Cancel" />
        </StackPanel>
      </Button>
      <TextBlock VerticalAlignment="Center"
                 Foreground="{ui:ThemeResource SystemFillColorSuccessBrush}"
                 FontWeight="SemiBold"
                 Visibility="{Binding IsComplete, Converter={StaticResource BoolToVisibility}}">
        &#xE73E; Apply complete
      </TextBlock>
    </StackPanel>
  </Grid>
</UserControl>
