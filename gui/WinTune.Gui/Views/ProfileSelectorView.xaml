<UserControl x:Class="WinTune.Gui.Views.ProfileSelectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WinTune.Gui.ViewModels"
             xmlns:ui="http://schemas.modernwpf.com/2019">
  <UserControl.DataContext>
    <vm:ProfileSelectorViewModel />
  </UserControl.DataContext>

  <Grid Margin="32">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <TextBlock Text="Profiles" FontSize="24" FontWeight="SemiBold" />
    <TextBlock Grid.Row="1" Text="Select a profile to audit, apply, or customize."
               FontSize="13" Foreground="{ui:ThemeResource TextFillSecondaryBrush}"
               Margin="0,4,0,24" />

    <!-- Loading -->
    <ui:ProgressRing Grid.Row="2" IsActive="{Binding IsLoading}"
                     Width="32" Height="32" Margin="0,16"
                     VerticalAlignment="Top"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}" />

    <!-- Error -->
    <Border Grid.Row="2" VerticalAlignment="Top"
            Background="#482222" CornerRadius="8" Padding="16,12"
            Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                   Foreground="#EA3943" VerticalAlignment="Center" Margin="0,0,12,0" />
        <TextBlock Grid.Column="1" Text="{Binding Error}" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- Profile Cards -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Profiles}" Margin="0,0,0,0">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="2" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border MinHeight="160" Margin="0,0,8,8" Padding="24,20"
                    CornerRadius="12"
                    Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="*" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="{Binding Name}" FontSize="17" FontWeight="SemiBold" />
                  <Border CornerRadius="4" Padding="6,2" Margin="12,0,0,0"
                          Background="{ui:ThemeResource SystemFillColorCriticalBrush}"
                          Visibility="{Binding Dangerous, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="DANGEROUS" FontSize="10" FontWeight="SemiBold" Foreground="#EA3943" />
                  </Border>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="{Binding Description}" Margin="0,10,0,0"
                           Foreground="{ui:ThemeResource TextFillSecondaryBrush}"
                           TextWrapping="Wrap" FontSize="13" MaxHeight="80" />

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,14,0,0">
                  <TextBlock FontSize="12" Foreground="{ui:ThemeResource SystemAccentColorBrush}">
                    <Run Text="{Binding TweakCount}" FontWeight="SemiBold" />
                    <Run Text=" tweaks" />
                  </TextBlock>
                  <Button Content="Select" Width="80" Height="28"
                          Margin="12,0,0,0" VerticalAlignment="Center"
                          Click="OnSelectProfileClick" Tag="{Binding Name}" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
