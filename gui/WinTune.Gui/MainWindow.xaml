<Window x:Class="WinTune.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:WinTune.Gui.Views"
        Title="WinTune" Height="800" Width="1280">
  <Grid>
    <NavigationView x:Name="Nav" PaneDisplayMode="LeftCompact" IsBackButtonVisible="Collapsed" IsSettingsVisible="False" CompactPaneLength="48" OpenPaneLength="220">
      <NavigationView.PaneHeader>
        <StackPanel Margin="0,4,0,0">
          <TextBlock Text="WinTune" FontSize="18" FontWeight="SemiBold" Margin="16,8,0,0" />
          <TextBlock Text="v0.3" FontSize="11" Foreground="#808080" Margin="16,2,0,12" />
        </StackPanel>
      </NavigationView.PaneHeader>
      <NavigationView.MenuItems>
        <NavigationViewItem Content="Dashboard" Tag="Dashboard" IsSelected="True">
          <NavigationViewItem.Icon><FontIcon Glyph="&#xE80F;" /></NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Profiles" Tag="Profiles">
          <NavigationViewItem.Icon><FontIcon Glyph="&#xE71D;" /></NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Audit" Tag="Audit">
          <NavigationViewItem.Icon><FontIcon Glyph="&#xE714;" /></NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Apply" Tag="Apply">
          <NavigationViewItem.Icon><FontIcon Glyph="&#xE768;" /></NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="History" Tag="Revert">
          <NavigationViewItem.Icon><FontIcon Glyph="&#xE81C;" /></NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.MenuItems>
      <Grid Margin="0,8,0,0">
        <views:DashboardView x:Name="DashboardView" Visibility="Visible" />
        <views:ProfileSelectorView x:Name="ProfileSelectorView" Visibility="Collapsed" />
        <views:AuditResultsView x:Name="AuditResultsView" Visibility="Collapsed" />
        <views:ApplyProgressView x:Name="ApplyProgressView" Visibility="Collapsed" />
        <views:RevertView x:Name="RevertView" Visibility="Collapsed" />
      </Grid>
    </NavigationView>
  </Grid>
</Window>
