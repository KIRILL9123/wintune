<Window x:Class="WinTune.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:WinTune.Gui.Views"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        mc:Ignorable="d"
        Title="WinTune — Windows Optimization"
        Width="1280" Height="800"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance}">
  <Grid>
    <ui:NavigationView x:Name="Nav"
                       PaneDisplayMode="LeftCompact"
                       IsBackButtonVisible="Collapsed"
                       IsSettingsVisible="False"
                       CompactPaneLength="48"
                       OpenPaneLength="220">
      <ui:NavigationView.PaneHeader>
        <StackPanel Margin="0,4,0,0">
          <TextBlock Text="WinTune"
                     FontSize="18" FontWeight="SemiBold"
                     Margin="16,8,0,0" />
          <TextBlock Text="v0.2"
                     FontSize="11"
                     Foreground="{ui:ThemeResource TextFillSecondaryBrush}"
                     Margin="16,2,0,12" />
        </StackPanel>
      </ui:NavigationView.PaneHeader>

      <ui:NavigationView.MenuItems>
        <ui:NavigationViewItem Content="Dashboard" Tag="Dashboard"
                               Icon="Home" IsSelected="True" />
        <ui:NavigationViewItem Content="Profiles" Tag="Profiles"
                               Icon="AllApps" />
        <ui:NavigationViewItem Content="Audit" Tag="Audit"
                               Icon="Scan" />
        <ui:NavigationViewItem Content="Apply" Tag="Apply"
                               Icon="Play" />
        <ui:NavigationViewItem Content="History" Tag="Revert"
                               Icon="History" />
      </ui:NavigationView.MenuItems>

      <ui:NavigationView.Content>
        <Grid Margin="0,8,0,0">
          <views:DashboardView x:Name="DashboardView" Visibility="Visible" />
          <views:ProfileSelectorView x:Name="ProfileSelectorView" Visibility="Collapsed" />
          <views:AuditResultsView x:Name="AuditResultsView" Visibility="Collapsed" />
          <views:ApplyProgressView x:Name="ApplyProgressView" Visibility="Collapsed" />
          <views:RevertView x:Name="RevertView" Visibility="Collapsed" />
        </Grid>
      </ui:NavigationView.Content>
    </ui:NavigationView>
  </Grid>
</Window>
