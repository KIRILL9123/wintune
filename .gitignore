# WinTune — .gitignore

# Logs
logs/*
!logs/.gitkeep
*.log

# Backups (stored in $env:LOCALAPPDATA\WinTune\backups\ by default)
backups/

# GUI build outputs
gui/**/bin/
gui/**/obj/
gui/.vs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
*.swp
*.swo
*~
.vscode/settings.json

# PowerShell
*.ps1xml
*.psd1
*.psm1  # We use dot-source, not modules
publish/
